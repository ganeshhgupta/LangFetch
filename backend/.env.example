# ============================================================
# LangFetch Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# REQUIRED — App won't start without this
# Get from: https://console.anthropic.com/
# Format: sk-ant-api03-...
# Leave blank to run in demo mode (pre-baked SQL responses)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model to use — claude-3-5-sonnet-20241022 recommended
# Other options: claude-3-haiku-20240307 (faster/cheaper)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ------------------------------------------------------------
# DATABASE — PostgreSQL (Neon recommended for free tier)
# Get from: https://neon.tech → New Project → Connection string
# Must use asyncpg driver prefix: postgresql+asyncpg://
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------
# CACHE — Redis (Upstash recommended for free tier)
# Get from: https://console.upstash.com → Create Database
# Use the "Redis URL" (starts with rediss:// for TLS)
# ------------------------------------------------------------
REDIS_URL=rediss://default:your-token@your-db.upstash.io:6379

# ------------------------------------------------------------
# VECTOR DB — Pinecone (for schema RAG embeddings)
# Get from: https://app.pinecone.io → API Keys
# Create an index named "langfetch" with dimension=1536
# NOTE: pip package is "pinecone" NOT "pinecone-client"
# ------------------------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=langfetch
PINECONE_ENVIRONMENT=us-east-1
